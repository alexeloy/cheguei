{
  "name": "cheguei",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/backend",
    "packages/web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=packages/backend\" \"npm run dev --workspace=packages/web\"",
    "dev:backend": "npm run dev --workspace=packages/backend",
    "dev:web": "npm run dev --workspace=packages/web",
    "dev:mobile": "cd packages/mobile && npm start",
    "seed": "npm run seed --workspace=packages/backend",
    "install:all": "npm install && cd packages/mobile && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
