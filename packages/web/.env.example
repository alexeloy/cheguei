# Backend API URL for production builds
# Leave empty to auto-detect from window.location
# This is only used in PRODUCTION builds (import.meta.env.PROD)
# In development, the Vite server will proxy /api requests to the backend
VITE_API_URL=http://localhost:3001

# WebSocket URL (optional, falls back to VITE_API_URL if not set)
VITE_WS_URL=http://localhost:3001
